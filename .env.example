# Database
POSTGRES_USER=coach
POSTGRES_PASSWORD=changeme
POSTGRES_DB=coach_hub
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# MinIO
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=changeme

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Qdrant
QDRANT_HOST=localhost
QDRANT_HTTP_PORT=6333  # HTTP port (AsyncQdrantClient, not gRPC)
VECTOR_SIZE=1024  # must match embedding model dimension

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# LiveKit
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_ROOM=coaching-room

# AI provider
# LLM_PROVIDER влияет на Simulator Agent (Phase 3a) и Coach Agent (Phase 3b):
#   mock          → rule-based агенты (нет LLM)
#   ollama        → локальный Ollama (qwen2.5:7b по умолчанию)
#   openai_compat → любой OpenAI-совместимый API (vLLM, OpenAI, Together, etc.)
#   gigachat      → Сбер GigaChat (через opencode-gigachat-plugin)
LLM_PROVIDER=mock
LLM_MODEL=mistral:7b-instruct     # модель Ollama / OpenAI
LLM_BASE_URL=http://localhost:11434/v1  # для Ollama / vLLM / OpenAI-совместимых прокси
LLM_API_KEY=                      # Bearer-токен (для openai_compat / прокси)
LLM_TIMEOUT=60                    # таймаут генерации (сек)
OPENAI_API_KEY=
EMBEDDING_URL=http://localhost:8001/v1/embeddings
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# OpenCode GigaChat plugin (Сбер)
# Креды хранятся в ~/.config/opencode/.env (НЕ коммитить, НЕ в этом файле).
# Base64 от строки "Client_ID:Client_Secret" из кабинета developers.sber.ru
# Сгенерировать можно через bin/encode-credentials.js из репо плагина.
GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Путь к PEM-бандлу корневых CA Минцифры РФ. По умолчанию плагин использует
# встроенный бандл, переопределять не нужно.
# GIGACHAT_CA_BUNDLE_FILE=
# Только для отладки/прокси. НЕ включать в проде.
# GIGACHAT_VERIFY_SSL=true

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info
